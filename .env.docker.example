# ─── Database Configuration ──────────────────────────────────────────────────
# Connection URL for Drizzle (Matches the 'db' service name in docker-compose)
DATABASE_URL=postgresql://medicare_user:securepassword@db:5432/medicare

# Credentials for the Postgres container
POSTGRES_USER=medicare_user
POSTGRES_PASSWORD=securepassword
POSTGRES_DB=medicare

# ─── Application Configuration ───────────────────────────────────────────────
# Port exposed to the host machine
APP_PORT=3000

# Next.js Environment
NODE_ENV=production

# ─── Admin Seed Configuration ────────────────────────────────────────────────
# Set to 'true' to create the admin user on first startup
SEED_ADMIN=true

# Initial Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@1234
ADMIN_FULLNAME=Administrateur Système

# ─── Security ────────────────────────────────────────────────────────────────
# Used for session security (should be a long random string in production)
SESSION_SECRET=your_super_secret_base64_string_here
