# ─── Database Configuration ──────────────────────────────────────────────────
# The app connects to the PostgreSQL installed on the Windows host machine.
# 'host.docker.internal' is the special DNS name Docker provides for this.
DATABASE_URL=postgresql://medicare_user:securepassword@host.docker.internal:5432/medicare

# Credentials matching your local Windows PostgreSQL setup
POSTGRES_USER=medicare_user
POSTGRES_PASSWORD=securepassword
POSTGRES_DB=medicare

# Port of the local PostgreSQL instance (default: 5432)
POSTGRES_PORT=5432

# ─── Application Configuration ───────────────────────────────────────────────
# Port exposed to the host machine
APP_PORT=3000

# Next.js Environment
NODE_ENV=production

# ─── Admin Seed Configuration ────────────────────────────────────────────────
# Set to 'true' to create the admin user on first startup, 'false' after
SEED_ADMIN=true
admin
# Initial Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@1234
ADMIN_FULLNAME=Administrateur Système

# ─── Security ────────────────────────────────────────────────────────────────
# Used for session security (generate with: openssl rand -base64 48)
SESSION_SECRET=your_super_secret_base64_string_here
